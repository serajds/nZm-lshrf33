{
  "expo": {
    "name": "إدارة الإشراف والمتابعة",
    "slug": "construction-supervision-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "supmobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#285a93"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.supervision.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج إلى الكاميرا لالتقاط صورة سيلفي عند تسجيل الحضور.",
        "NSLocationWhenInUseUsageDescription": "نحتاج إلى موقعك للتحقق من تواجدك داخل نطاق الموقع عند تسجيل الحضور.",
        "NSPhotoLibraryUsageDescription": "نستخدم مكتبة الصور لاختيار صورة عند الحاجة."
      }
    },
    "android": {
      "package": "com.supervision.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "نحتاج إلى الكاميرا لالتقاط صورة سيلفي عند تسجيل الحضور."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "نحتاج إلى الكاميرا لالتقاط صورة سيلفي عند تسجيل الحضور.",
          "photosPermission": "نستخدم مكتبة الصور لاختيار صورة عند الحاجة."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج إلى موقعك للتحقق من تواجدك داخل نطاق الموقع عند تسجيل الحضور."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#285a93",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
